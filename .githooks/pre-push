#!/bin/sh
# pre-push — runs make check before every push.
#
# Blocks the push if go test -race, golangci-lint, or the examples static gate
# fails. (`make check` depends on `lint-examples`, so the static gate runs as
# part of check.) This mirrors CI exactly (see .github/workflows/ci.yml).
#
# One-time setup:
#   git config core.hooksPath .githooks
#
# To skip in an emergency (not recommended):
#   git push --no-verify

set -e

echo "[pre-push] running make check …"
make check
echo "[pre-push] check passed."
